generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & User ────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile         UserProfile?
  sessions        Session[]
  consentSettings ConsentSettings?
  studySessions   StudySession[]
  tutorThreads    TutorThread[]
  emotionSamples  EmotionSample[]
  flashcardDecks  FlashcardDeck[]
}

model UserProfile {
  id          String @id @default(uuid())
  userId      String @unique
  displayName String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id // nanoid token
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ConsentSettings {
  userId                  String  @id
  emotionTelemetryAllowed Boolean @default(false)
  webcamAllowed           Boolean @default(false)
  retentionDays           Int     @default(30)
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Study Sessions & Tutor ─────────────────────────────

model StudySession {
  id        String    @id @default(uuid())
  userId    String
  topic     String?
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorThreads   TutorThread[]
  emotionSamples EmotionSample[]

  @@index([userId])
}

model TutorThread {
  id        String   @id @default(uuid())
  userId    String
  sessionId String
  title     String?
  createdAt DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session        StudySession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages       TutorMessage[]
  emotionSamples EmotionSample[]

  @@index([userId])
  @@index([sessionId])
}

model TutorMessage {
  id        String      @id @default(uuid())
  threadId  String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  thread TutorThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([createdAt])
}

enum MessageRole {
  user
  assistant
  system
}

// ─── Emotions ───────────────────────────────────────────

model EmotionSample {
  id        String        @id @default(uuid())
  userId    String
  sessionId String?
  threadId  String?
  timestamp DateTime      @default(now())
  source    EmotionSource
  label     EmotionLabel
  meta      Json?

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session StudySession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  thread  TutorThread?  @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([threadId])
  @@index([timestamp])
}

enum EmotionSource {
  self_report
  webcam
}

enum EmotionLabel {
  happy
  sad
  frustrated
  confused
  bored
  neutral
}

// ─── Flashcards ─────────────────────────────────────────

model FlashcardDeck {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards FlashcardCard[]

  @@index([userId])
}

model FlashcardCard {
  id        String   @id @default(uuid())
  deckId    String
  front     String
  back      String
  tags      String[] @default([])
  createdAt DateTime @default(now())

  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId])
}
