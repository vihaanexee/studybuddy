# Database
DATABASE_URL=postgresql://user:password@localhost:5432/studybuddy?schema=public

# Server
PORT=4000
NODE_ENV=development

# Auth
COOKIE_SECRET=your-super-secret-cookie-key-at-least-32-characters-long
SESSION_TTL_HOURS=72

# AI
# auto uses Anthropic when ANTHROPIC_API_KEY is present, otherwise a no-key demo tutor.
# Use AI_PROVIDER=minimax to call MiniMax's OpenAI-compatible chat API.
# Use AI_PROVIDER=openrouter with an OpenRouter API key and model id.
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=minimax/minimax-m2.7

# CORS
FRONTEND_ORIGIN=http://localhost:3000
